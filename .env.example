# Runtime environment
NODE_ENV=development

# Backend server port (1024-65535)
PORT=3001

# JWT HMAC secret (minimum 32 characters)
JWT_SECRET=replace-with-a-minimum-32-character-secret-value

# Comma-separated CORS origins
ALLOWED_ORIGINS=http://localhost:5173,https://localhost

# Logging level: error | warn | info | debug
LOG_LEVEL=info

# Trust reverse proxy headers (set true behind NGINX/ALB)
TRUST_PROXY=false

# Maximum request processing time in milliseconds
REQUEST_TIMEOUT_MS=10000

# Graceful shutdown timeout in milliseconds
SHUTDOWN_GRACE_MS=10000

# Key vault default TTL in hours
KEY_VAULT_TTL_HOURS=24
